<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.community.content.mapper.CmsArticleMapper">

    <resultMap type="com.moyun.community.content.entity.CmsArticle" id="CmsArticleResult">
        <id property="articleId" column="article_id" />
        <result property="categoryId" column="category_id" />
        <result property="authorId" column="author_id" />
        <result property="title" column="title" />
        <result property="summary" column="summary" />
        <result property="coverUrl" column="cover_url" />
        <result property="content" column="content" />
        <result property="contentType" column="content_type" />
        <result property="articleType" column="article_type" />
        <result property="sourceType" column="source_type" />
        <result property="originalUrl" column="original_url" />
        <result property="wordCount" column="word_count" />
        <result property="readingTime" column="reading_time" />
        <result property="status" column="status" />
        <result property="isTop" column="is_top" />
        <result property="isRecommend" column="is_recommend" />
        <result property="isDeleted" column="is_deleted" />
        <result property="viewCount" column="view_count" />
        <result property="likeCount" column="like_count" />
        <result property="collectCount" column="collect_count" />
        <result property="commentCount" column="comment_count" />
        <result property="shareCount" column="share_count" />
        <result property="rewardCount" column="reward_count" />
        <result property="allowComment" column="allow_comment" />
        <result property="publishTime" column="publish_time" />
        <result property="auditTime" column="audit_time" />
        <result property="auditReason" column="audit_reason" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectArticleVo">
        select article_id, category_id, author_id, title, summary, cover_url, content, content_type,
               article_type, source_type, original_url, word_count, reading_time, status, is_top,
               is_recommend, is_deleted, view_count, like_count, collect_count, comment_count,
               share_count, reward_count, allow_comment, publish_time, audit_time, audit_reason,
               create_by, create_time, update_by, update_time, remark
        from cms_article
    </sql>

    <select id="selectArticleList" parameterType="com.moyun.community.content.entity.CmsArticle" resultMap="CmsArticleResult">
        <include refid="selectArticleVo" />
        <where>
            is_deleted = 0
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}, '%')
            </if>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="authorId != null">
                AND author_id = #{authorId}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectArticleById" parameterType="Long" resultMap="CmsArticleResult">
        <include refid="selectArticleVo" />
        where article_id = #{articleId}
    </select>

    <select id="selectHomeRecommendList" resultMap="CmsArticleResult">
        <include refid="selectArticleVo" />
        where status = 'published' and is_recommend = 1 and is_deleted = 0
        order by publish_time desc
        limit 10
    </select>

    <select id="selectHotArticleList" resultMap="CmsArticleResult">
        <include refid="selectArticleVo" />
        where status = 'published' and is_deleted = 0
        order by view_count desc
        limit 10
    </select>

    <select id="selectLatestArticleList" resultMap="CmsArticleResult">
        <include refid="selectArticleVo" />
        where status = 'published' and is_deleted = 0
        order by publish_time desc
        limit 10
    </select>

    <select id="selectArticleListByCategory" parameterType="Long" resultMap="CmsArticleResult">
        <include refid="selectArticleVo" />
        where category_id = #{categoryId} and status = 'published' and is_deleted = 0
        order by publish_time desc
    </select>

    <select id="selectMyArticleList" parameterType="Long" resultMap="CmsArticleResult">
        <include refid="selectArticleVo" />
        where author_id = #{authorId} and is_deleted = 0
        order by create_time desc
    </select>

    <select id="selectPendingAuditList" resultMap="CmsArticleResult">
        <include refid="selectArticleVo" />
        where status = 'pending' and is_deleted = 0
        order by publish_time desc
    </select>

    <update id="updateArticleStatus">
        update cms_article
        set status = #{status}, update_time = sysdate()
        where article_id = #{articleId}
    </update>

    <update id="incrementViewCount">
        update cms_article
        set view_count = view_count + 1
        where article_id = #{articleId}
    </update>

    <update id="incrementLikeCount">
        update cms_article
        set like_count = like_count + 1
        where article_id = #{articleId}
    </update>

    <update id="incrementCollectCount">
        update cms_article
        set collect_count = collect_count + 1
        where article_id = #{articleId}
    </update>

    <update id="incrementCommentCount">
        update cms_article
        set comment_count = comment_count + 1
        where article_id = #{articleId}
    </update>

</mapper>