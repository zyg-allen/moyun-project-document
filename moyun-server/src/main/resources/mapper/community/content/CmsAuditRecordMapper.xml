    <sql id="selectAuditRecordVo">
        select audit_id, article_id, submit_user_id, auditor_id, audit_status, audit_type, ai_result,
               ai_score, audit_reason, audit_remark, submit_time, audit_time, create_by, create_time,
               update_by, update_time
