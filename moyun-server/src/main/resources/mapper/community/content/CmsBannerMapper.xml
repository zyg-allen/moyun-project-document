<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.community.content.mapper.CmsBannerMapper">

    <resultMap type="com.moyun.community.content.entity.CmsBanner" id="CmsBannerResult">
        <id property="bannerId" column="banner_id" />
        <result property="title" column="title" />
        <result property="imageUrl" column="image_url" />
        <result property="jumpType" column="jump_type" />
        <result property="jumpValue" column="jump_value" />
        <result property="jumpParams" column="jump_params" />
        <result property="sort" column="sort" />
        <result property="status" column="status" />
        <result property="startTime" column="start_time" />
        <result property="endTime" column="end_time" />
        <result property="position" column="position" />
        <result property="clickCount" column="click_count" />
        <result property="exposureCount" column="exposure_count" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectBannerVo">
        select banner_id, title, image_url, jump_type, jump_value, jump_params, sort, status,
               start_time, end_time, position, click_count, exposure_count, create_by, create_time,
               update_by, update_time, remark
        from cms_banner
    </sql>

    <select id="selectBannerList" resultMap="CmsBannerResult">
        <include refid="selectBannerVo" />
        where status = '0'
        order by sort asc
    </select>

</mapper>