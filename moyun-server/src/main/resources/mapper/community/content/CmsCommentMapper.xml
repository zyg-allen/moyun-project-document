<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.community.content.mapper.CmsCommentMapper">

    <resultMap type="com.moyun.community.content.entity.CmsComment" id="CmsCommentResult">
        <id property="commentId" column="comment_id" />
        <result property="articleId" column="article_id" />
        <result property="userId" column="user_id" />
        <result property="parentId" column="parent_id" />
        <result property="replyId" column="reply_id" />
        <result property="replyUserId" column="reply_user_id" />
        <result property="content" column="content" />
        <result property="likeCount" column="like_count" />
        <result property="status" column="status" />
        <result property="ipAddress" column="ip_address" />
        <result property="deviceType" column="device_type" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectCommentVo">
        select comment_id, article_id, user_id, parent_id, reply_id, reply_user_id, content,
               like_count, status, ip_address, device_type, create_by, create_time, update_by,
               update_time, remark
        from cms_comment
    </sql>

    <select id="selectCommentListByArticle" parameterType="Long" resultMap="CmsCommentResult">
        <include refid="selectCommentVo" />
        where article_id = #{articleId} and status != '2'
        order by create_time desc
    </select>

    <select id="selectCommentListByUser" parameterType="Long" resultMap="CmsCommentResult">
        <include refid="selectCommentVo" />
        where user_id = #{userId} and status != '2'
        order by create_time desc
    </select>

    <update id="incrementLikeCount">
        update cms_comment
        set like_count = like_count + 1
        where comment_id = #{commentId}
    </update>

</mapper>