<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.community.content.mapper.CmsSearchHistoryMapper">

    <resultMap type="com.moyun.community.content.entity.CmsSearchHistory" id="CmsSearchHistoryResult">
        <id property="historyId" column="history_id" />
        <result property="userId" column="user_id" />
        <result property="keyword" column="keyword" />
        <result property="resultCount" column="result_count" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectHistoryVo">
        select history_id, user_id, keyword, result_count, create_by, create_time, update_by, update_time
        from cms_search_history
    </sql>

    <select id="selectSearchHistoryList" parameterType="Long" resultMap="CmsSearchHistoryResult">
        <include refid="selectHistoryVo" />
        where user_id = #{userId}
        order by create_time desc
        limit 20
    </select>

    <delete id="deleteUserSearchHistory" parameterType="Long">
        delete from cms_search_history where user_id = #{userId}
    </delete>

</mapper>