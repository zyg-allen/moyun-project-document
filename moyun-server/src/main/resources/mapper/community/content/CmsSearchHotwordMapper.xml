<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.community.content.mapper.CmsSearchHotwordMapper">

    <resultMap type="com.moyun.community.content.entity.CmsSearchHotword" id="CmsSearchHotwordResult">
        <id property="hotwordId" column="hotword_id" />
        <result property="keyword" column="keyword" />
        <result property="searchCount" column="search_count" />
        <result property="sort" column="sort" />
        <result property="status" column="status" />
        <result property="type" column="type" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectHotwordVo">
        select hotword_id, keyword, search_count, sort, status, type, create_by, create_time,
               update_by, update_time
        from cms_search_hotword
    </sql>

    <select id="selectHotwordList" resultMap="CmsSearchHotwordResult">
        <include refid="selectHotwordVo" />
        where status = '0'
        order by sort asc
        limit 10
    </select>

    <update id="incrementSearchCount">
        update cms_search_hotword
        set search_count = search_count + 1
        where hotword_id = #{hotwordId}
    </update>

</mapper>