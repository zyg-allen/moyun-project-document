<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalArticleTagMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalArticleTag" id="PortalArticleTagResult">
        <id property="id" column="id"/>
        <result property="articleId" column="article_id"/>
        <result property="tagId" column="tag_id"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectPortalArticleTagVo">
        select id, article_id, tag_id, create_time from portal_article_tag
    </sql>

    <select id="selectPortalArticleTagList" parameterType="com.moyun.portal.domain.entity.PortalArticleTag" resultMap="PortalArticleTagResult">
        <include refid="selectPortalArticleTagVo"/>
        <where>
            <if test="articleId != null">and article_id = #{articleId}</if>
            <if test="tagId != null">and tag_id = #{tagId}</if>
        </where>
    </select>

    <select id="selectPortalArticleTagById" parameterType="Long" resultMap="PortalArticleTagResult">
        <include refid="selectPortalArticleTagVo"/>
        where article_id = #{arg0} and tag_id = #{arg1}
    </select>

    <insert id="insertPortalArticleTag" parameterType="com.moyun.portal.domain.entity.PortalArticleTag" useGeneratedKeys="true" keyProperty="id">
        insert into portal_article_tag
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="articleId != null">article_id,</if>
            <if test="tagId != null">tag_id,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="articleId != null">#{articleId},</if>
            <if test="tagId != null">#{tagId},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <insert id="batchInsertPortalArticleTag" parameterType="java.util.List">
        insert into portal_article_tag (article_id, tag_id, create_time)
        values
        <foreach collection="list" item="item" index="index" separator=",">
            (#{item.articleId}, #{item.tagId}, #{item.createTime})
        </foreach>
    </insert>

    <delete id="deletePortalArticleTagByArticleId" parameterType="Long">
        delete from portal_article_tag where article_id = #{articleId}
    </delete>

    <delete id="deletePortalArticleTagByArticleIds" parameterType="Long">
        delete from portal_article_tag where article_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
