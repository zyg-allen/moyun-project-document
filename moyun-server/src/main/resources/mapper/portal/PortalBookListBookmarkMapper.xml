<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalBookListBookmarkMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalBookListBookmark" id="PortalBookListBookmarkResult">
        <id     property="id"          column="id"           />
        <result property="booklistId"  column="booklist_id"  />
        <result property="userId"      column="user_id"      />
        <result property="createTime"  column="create_time"  />
    </resultMap>

    <select id="selectBookmark" resultMap="PortalBookListBookmarkResult">
        select id, booklist_id, user_id, create_time
        from portal_book_list_bookmark
        where booklist_id = #{booklistId} and user_id = #{userId}
        limit 1
    </select>

    <select id="countByBooklist" resultType="long">
        select count(1) from portal_book_list_bookmark where booklist_id = #{booklistId}
    </select>

</mapper>
