        <result property="summary"       column="summary"       />
        <result property="isbn"          column="isbn"          />
        <result property="publisher"     column="publisher"     />
        <result property="publishDate"   column="publish_date"  />
        <result property="pageCount"     column="page_count"    />
        <result property="categoryId"    column="category_id"   />
        <result property="tags"          column="tags"          />
        <result property="rating"        column="rating"        />
        <result property="readingCount"  column="reading_count" />
        <result property="status"        column="status"        />
        <result property="type"          column="type"          />
        <result property="serialStatus"  column="serial_status" />
        <result property="wordCount"     column="word_count"    />
        <result property="chapterCount"  column="chapter_count" />
        <result property="latestChapterId"    column="latest_chapter_id"    />
