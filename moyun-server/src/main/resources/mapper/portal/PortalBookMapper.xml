        <result property="updateBy"      column="update_by"     />
        <result property="updateTime"    column="update_time"   />
        <result property="remark"        column="remark"        />
    </resultMap>

    <sql id="selectPortalBookVo">
        select id, title, author, cover, description, summary, isbn, publisher, publish_date,
               page_count, category_id, tags, rating, reading_count, status,
               type, serial_status, word_count, chapter_count,
               latest_chapter_id, latest_chapter_title, last_update_time, is_finished,
               access_level, preview_ratio, price, is_featured, is_recommended, author_bio,
               create_by, create_time, update_by, update_time, remark
        from portal_book
    </sql>

    <select id="selectPortalBookPage" parameterType="com.moyun.portal.domain.query.BookQuery" resultMap="PortalBookResult">
        <include refid="selectPortalBookVo"/>
        <where>
            <if test="query.title != null and query.title != ''">
                AND title like concat('%', #{query.title}, '%')
            </if>
            <if test="query.author != null and query.author != ''">
                AND author like concat('%', #{query.author}, '%')
            </if>
            <if test="query.isbn != null and query.isbn != ''">
                AND isbn = #{query.isbn}
            </if>
            <if test="query.categoryId != null">
                AND category_id = #{query.categoryId}
            </if>
            <if test="query.status != null and query.status != ''">
                AND status = #{query.status}
            </if>
            <if test="query.accessLevel != null and query.accessLevel != ''">
                AND access_level = #{query.accessLevel}
            </if>
            <if test="query.isFeatured != null">
                AND is_featured = #{query.isFeatured}
            </if>
            <if test="query.tag != null and query.tag != ''">
                AND tags like concat('%', #{query.tag}, '%')
            </if>
            <if test="query.isFinished != null">
                AND is_finished = #{query.isFinished}
            </if>
            <if test="query.type != null and query.type != ''">
                AND type = #{query.type}
            </if>
        </where>
        <choose>
            <when test="query.orderBy == 'new'">
                order by create_time desc, id desc
            </when>
            <when test="query.orderBy == 'word_count'">
                order by word_count desc, id desc
            </when>
            <otherwise>
                order by reading_count desc, id desc
            </otherwise>
        </choose>
    </select>

    <select id="selectPortalBookList" parameterType="com.moyun.portal.domain.query.BookQuery" resultMap="PortalBookResult">
        <include refid="selectPortalBookVo"/>
        <where>
            <if test="query.title != null and query.title != ''">
                AND title like concat('%', #{query.title}, '%')
            </if>
            <if test="query.author != null and query.author != ''">
                AND author like concat('%', #{query.author}, '%')
            </if>
            <if test="query.categoryId != null">
                AND category_id = #{query.categoryId}
            </if>
            <if test="query.status != null and query.status != ''">
                AND status = #{query.status}
            </if>
            <if test="query.isFeatured != null">
                AND is_featured = #{query.isFeatured}
            </if>
        </where>
        order by reading_count desc
    </select>

    <select id="selectPortalBookById" parameterType="Long" resultMap="PortalBookResult">
        <include refid="selectPortalBookVo"/>
        where id = #{id}
    </select>

    <insert id="insertPortalBook" parameterType="com.moyun.portal.domain.entity.PortalBook" useGeneratedKeys="true" keyProperty="id">
