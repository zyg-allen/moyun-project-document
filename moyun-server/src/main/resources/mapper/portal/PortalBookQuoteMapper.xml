<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalBookQuoteMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalBookQuote" id="PortalBookQuoteResult">
        <id     property="id"            column="id"            />
        <result property="userId"        column="user_id"       />
        <result property="bookId"        column="book_id"       />
        <result property="content"       column="content"       />
        <result property="page"          column="page"          />
        <result property="chapter"       column="chapter"       />
        <result property="location"      column="location"      />
        <result property="likeCount"     column="like_count"    />
        <result property="isPublic"      column="is_public"     />
        <result property="isFeatured"    column="is_featured"   />
        <result property="createTime"    column="create_time"   />
        <result property="updateTime"    column="update_time"   />
    </resultMap>

    <sql id="selectPortalBookQuoteVo">
        select id, user_id, book_id, content, page, chapter, location, like_count,
               is_public, is_featured, create_time, update_time
        from portal_book_quote
    </sql>

    <select id="selectPortalBookQuotePage" parameterType="com.moyun.portal.domain.query.BookQuoteQuery" resultMap="PortalBookQuoteResult">
        <include refid="selectPortalBookQuoteVo"/>
        <where>
            <if test="query.userId != null">
                AND user_id = #{query.userId}
            </if>
            <if test="query.bookId != null">
                AND book_id = #{query.bookId}
            </if>
            <if test="query.content != null and query.content != ''">
                AND content like concat('%', #{query.content}, '%')
            </if>
            <if test="query.isPublic != null">
                AND is_public = #{query.isPublic}
            </if>
            <if test="query.isFeatured != null">
                AND is_featured = #{query.isFeatured}
            </if>
        </where>
        order by like_count desc, id desc
    </select>

    <select id="selectPortalBookQuoteList" parameterType="com.moyun.portal.domain.query.BookQuoteQuery" resultMap="PortalBookQuoteResult">
        <include refid="selectPortalBookQuoteVo"/>
        <where>
            <if test="query.userId != null">
                AND user_id = #{query.userId}
            </if>
            <if test="query.bookId != null">
                AND book_id = #{query.bookId}
            </if>
            <if test="query.isPublic != null">
                AND is_public = #{query.isPublic}
            </if>
        </where>
        order by id desc
    </select>

    <select id="selectPortalBookQuoteById" parameterType="Long" resultMap="PortalBookQuoteResult">
        <include refid="selectPortalBookQuoteVo"/>
        where id = #{id}
    </select>

    <insert id="insertPortalBookQuote" parameterType="com.moyun.portal.domain.entity.PortalBookQuote" useGeneratedKeys="true" keyProperty="id">
        insert into portal_book_quote
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="bookId != null">book_id,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="page != null and page != ''">page,</if>
            <if test="chapter != null and chapter != ''">chapter,</if>
            <if test="location != null and location != ''">location,</if>
            <if test="likeCount != null">like_count,</if>
            <if test="isPublic != null">is_public,</if>
            <if test="isFeatured != null">is_featured,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="bookId != null">#{bookId},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="page != null and page != ''">#{page},</if>
            <if test="chapter != null and chapter != ''">#{chapter},</if>
            <if test="location != null and location != ''">#{location},</if>
            <if test="likeCount != null">#{likeCount},</if>
            <if test="isPublic != null">#{isPublic},</if>
            <if test="isFeatured != null">#{isFeatured},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updatePortalBookQuote" parameterType="com.moyun.portal.domain.entity.PortalBookQuote">
        update portal_book_quote
        <trim prefix="SET" suffixOverrides=",">
            <if test="bookId != null">book_id = #{bookId},</if>
            <if test="content != null">content = #{content},</if>
            <if test="page != null">page = #{page},</if>
            <if test="chapter != null">chapter = #{chapter},</if>
            <if test="location != null">location = #{location},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="isPublic != null">is_public = #{isPublic},</if>
            <if test="isFeatured != null">is_featured = #{isFeatured},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePortalBookQuoteById" parameterType="Long">
        delete from portal_book_quote where id = #{id}
    </delete>

    <delete id="deletePortalBookQuoteByIds" parameterType="Long">
        delete from portal_book_quote where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
