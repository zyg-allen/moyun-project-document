<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalCommentLikeMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalCommentLike" id="PortalCommentLikeResult">
        <result property="id"         column="id"/>
        <result property="commentId"  column="comment_id"/>
        <result property="userId"     column="user_id"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectLike" resultMap="PortalCommentLikeResult">
        SELECT id, comment_id, user_id, create_time
        FROM portal_comment_like
        WHERE comment_id = #{commentId}
          AND user_id    = #{userId}
        LIMIT 1
    </select>

</mapper>
