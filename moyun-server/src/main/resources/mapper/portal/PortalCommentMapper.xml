<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalCommentMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalComment" id="PortalCommentResult">
        <id property="id" column="id"/>
        <result property="articleId" column="article_id"/>
        <result property="authorId" column="author_id"/>
        <result property="content" column="content"/>
        <result property="parentId" column="parent_id"/>
        <result property="rootId" column="root_id"/>
        <result property="replyTo" column="reply_to"/>
        <result property="replyToContent" column="reply_to_content"/>
        <result property="likeCount" column="like_count"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectPortalCommentVo">
        select id, article_id, author_id, content, parent_id, root_id, reply_to, reply_to_content, like_count, status, create_by, create_time, update_by, update_time, remark from portal_comment
    </sql>

    <!-- 分页查询 -->
    <select id="selectPortalCommentPage" resultMap="PortalCommentResult">
        <include refid="selectPortalCommentVo"/>
        <where>
            <if test="params.articleId != null">and article_id = #{params.articleId}</if>
            <if test="params.authorId != null">and author_id = #{params.authorId}</if>
            <if test="params.parentId != null">and parent_id = #{params.parentId}</if>
            <if test="params.status != null and params.status != ''">and status = #{params.status}</if>
        </where>
        order by create_time desc
    </select>

    <!-- 不分页查询（用于导出等场景） -->
    <select id="selectPortalCommentList" resultMap="PortalCommentResult">
        <include refid="selectPortalCommentVo"/>
        <where>
            <if test="params.articleId != null">and article_id = #{params.articleId}</if>
            <if test="params.authorId != null">and author_id = #{params.authorId}</if>
            <if test="params.parentId != null">and parent_id = #{params.parentId}</if>
            <if test="params.status != null and params.status != ''">and status = #{params.status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectPortalCommentById" parameterType="Long" resultMap="PortalCommentResult">
        <include refid="selectPortalCommentVo"/>
        where id = #{id}
    </select>

    <insert id="insertPortalComment" parameterType="com.moyun.portal.domain.entity.PortalComment" useGeneratedKeys="true" keyProperty="id">
        insert into portal_comment
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="articleId != null">article_id,</if>
            <if test="authorId != null">author_id,</if>
            <if test="content != null">content,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="rootId != null">root_id,</if>
            <if test="replyTo != null">reply_to,</if>
            <if test="replyToContent != null">reply_to_content,</if>
            <if test="likeCount != null">like_count,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="articleId != null">#{articleId},</if>
            <if test="authorId != null">#{authorId},</if>
            <if test="content != null">#{content},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="rootId != null">#{rootId},</if>
            <if test="replyTo != null">#{replyTo},</if>
            <if test="replyToContent != null">#{replyToContent},</if>
            <if test="likeCount != null">#{likeCount},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePortalComment" parameterType="com.moyun.portal.domain.entity.PortalComment">
        update portal_comment
        <trim prefix="SET" suffixOverrides=",">
            <if test="articleId != null">article_id = #{articleId},</if>
            <if test="authorId != null">author_id = #{authorId},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="rootId != null">root_id = #{rootId},</if>
            <if test="replyTo != null">reply_to = #{replyTo},</if>
            <if test="replyToContent != null">reply_to_content = #{replyToContent},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePortalCommentById" parameterType="Long">
        delete from portal_comment where id = #{id}
    </delete>

    <delete id="deletePortalCommentByIds" parameterType="Long">
        delete from portal_comment where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
