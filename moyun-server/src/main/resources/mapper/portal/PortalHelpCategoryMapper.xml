<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalHelpCategoryMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalHelpCategory" id="PortalHelpCategoryResult">
        <id     property="id"          column="id"          />
        <result property="name"        column="name"         />
        <result property="icon"        column="icon"         />
        <result property="description" column="description"  />
        <result property="sort"        column="sort"         />
        <result property="status"      column="status"       />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"  column="create_time"  />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"  column="update_time"  />
        <result property="remark"      column="remark"        />
    </resultMap>

    <sql id="selectHelpCategoryVo">
        select id, name, icon, description, sort, status, create_by, create_time, update_by, update_time, remark
        from portal_help_category
    </sql>

    <select id="selectHelpCategoryPage" resultMap="PortalHelpCategoryResult">
        <include refid="selectHelpCategoryVo"/>
        <where>
            <if test="category.name != null and category.name != ''">
                AND name like concat('%', #{category.name}, '%')
            </if>
            <if test="category.status != null and category.status != ''">
                AND status = #{category.status}
            </if>
        </where>
        order by sort asc, id asc
    </select>

    <select id="selectHelpCategoryList" resultMap="PortalHelpCategoryResult">
        <include refid="selectHelpCategoryVo"/>
        <where>
            <if test="category.name != null and category.name != ''">
                AND name like concat('%', #{category.name}, '%')
            </if>
            <if test="category.status != null and category.status != ''">
                AND status = #{category.status}
            </if>
        </where>
        order by sort asc, id asc
    </select>

    <select id="selectActiveCategoryList" resultMap="PortalHelpCategoryResult">
        <include refid="selectHelpCategoryVo"/>
        where status = 'active'
        order by sort asc, id asc
    </select>

</mapper>
