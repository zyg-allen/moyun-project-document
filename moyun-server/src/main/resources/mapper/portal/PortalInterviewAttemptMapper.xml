<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalInterviewAttemptMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalInterviewAttempt" id="PortalInterviewAttemptResult">
        <id     property="id"             column="id"             />
        <result property="questionId"     column="question_id"    />
        <result property="userId"         column="user_id"        />
        <result property="attemptCount"   column="attempt_count"  />
        <result property="lastAttemptAt"  column="last_attempt_at" />
        <result property="status"         column="status"         />
        <result property="firstSolvedAt"  column="first_solved_at" />
        <result property="lastSolvedAt"   column="last_solved_at"  />
    </resultMap>

    <select id="selectAttempt" resultMap="PortalInterviewAttemptResult">
        select id, question_id, user_id, attempt_count, last_attempt_at, status, first_solved_at, last_solved_at
        from portal_interview_attempt
        where question_id = #{questionId} and user_id = #{userId}
        limit 1
    </select>

    <select id="selectAttemptListByUserId" resultMap="PortalInterviewAttemptResult">
        select id, question_id, user_id, attempt_count, last_attempt_at, status, first_solved_at, last_solved_at
        from portal_interview_attempt
        where user_id = #{userId}
        order by last_attempt_at desc
    </select>

</mapper>
