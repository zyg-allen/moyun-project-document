<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalInterviewBookmarkMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalInterviewBookmark" id="PortalInterviewBookmarkResult">
        <id     property="id"         column="id"         />
        <result property="questionId" column="question_id" />
        <result property="userId"     column="user_id"    />
        <result property="note"       column="note"       />
        <result property="createTime" column="create_time" />
    </resultMap>

    <select id="selectBookmark" resultMap="PortalInterviewBookmarkResult">
        select id, question_id, user_id, note, create_time
        from portal_interview_bookmark
        where question_id = #{questionId} and user_id = #{userId}
        limit 1
    </select>

    <select id="selectBookmarkListByUserId" resultMap="PortalInterviewBookmarkResult">
        select id, question_id, user_id, note, create_time
        from portal_interview_bookmark
        where user_id = #{userId}
        order by create_time desc
    </select>

</mapper>
