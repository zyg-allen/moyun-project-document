<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalInterviewCategoryMapper">
    
    <resultMap type="com.moyun.portal.domain.entity.PortalInterviewCategory" id="PortalInterviewCategoryResult">
        <id     property="id"          column="id"          />
        <result property="name"        column="name"        />
        <result property="slug"        column="slug"        />
        <result property="description" column="description" />
        <result property="icon"        column="icon"        />
        <result property="sort"        column="sort"        />
        <result property="questionCount" column="question_count" />
        <result property="status"      column="status"      />
        <result property="createBy"    column="create_by"   />
        <result property="createTime"  column="create_time" />
        <result property="updateBy"    column="update_by"   />
        <result property="updateTime"  column="update_time" />
        <result property="remark"      column="remark"      />
    </resultMap>

    <sql id="selectPortalInterviewCategoryVo">
        select id, name, slug, description, icon, sort, question_count, status, create_by, create_time, update_by, update_time, remark 
        from portal_interview_category
    </sql>

    <select id="selectPortalInterviewCategoryList" parameterType="com.moyun.portal.domain.entity.PortalInterviewCategory" resultMap="PortalInterviewCategoryResult">
        <include refid="selectPortalInterviewCategoryVo"/>
        <where>  
            <if test="name != null and name != ''">
                AND name like concat('%', #{name}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by sort asc
    </select>
    
    <select id="selectPortalInterviewCategoryById" parameterType="Long" resultMap="PortalInterviewCategoryResult">
        <include refid="selectPortalInterviewCategoryVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertPortalInterviewCategory" parameterType="com.moyun.portal.domain.entity.PortalInterviewCategory" useGeneratedKeys="true" keyProperty="id">
        insert into portal_interview_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="slug != null and slug != ''">slug,</if>
            <if test="description != null">description,</if>
            <if test="icon != null and icon != ''">icon,</if>
            <if test="sort != null">sort,</if>
            <if test="questionCount != null">question_count,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null and remark != ''">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="slug != null and slug != ''">#{slug},</if>
            <if test="description != null">#{description},</if>
            <if test="icon != null and icon != ''">#{icon},</if>
            <if test="sort != null">#{sort},</if>
            <if test="questionCount != null">#{questionCount},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
         </trim>
    </insert>

    <update id="updatePortalInterviewCategory" parameterType="com.moyun.portal.domain.entity.PortalInterviewCategory">
        update portal_interview_category
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="slug != null and slug != ''">slug = #{slug},</if>
            <if test="description != null">description = #{description},</if>
            <if test="icon != null and icon != ''">icon = #{icon},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="questionCount != null">question_count = #{questionCount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePortalInterviewCategoryById" parameterType="Long">
        delete from portal_interview_category where id = #{id}
    </delete>

    <delete id="deletePortalInterviewCategoryByIds" parameterType="Long">
        delete from portal_interview_category where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
