<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalInterviewExperienceMapper">
    
    <resultMap type="com.moyun.portal.domain.entity.PortalInterviewExperience" id="PortalInterviewExperienceResult">
        <id     property="id"           column="id"            />
        <result property="userId"       column="user_id"       />
        <result property="title"        column="title"         />
        <result property="company"      column="company"       />
        <result property="position"     column="position"      />
        <result property="year"         column="year"          />
        <result property="month"        column="month"         />
        <result property="content"      column="content"       />
        <result property="tags"         column="tags"          />
        <result property="viewCount"    column="view_count"    />
        <result property="likeCount"    column="like_count"    />
        <result property="commentCount" column="comment_count" />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectPortalInterviewExperienceVo">
        select id, user_id, title, company, position, year, month, content, tags, view_count, like_count, comment_count, status, create_by, create_time, update_by, update_time, remark 
        from portal_interview_experience
    </sql>

    <select id="selectPortalInterviewExperienceList" parameterType="com.moyun.portal.domain.entity.PortalInterviewExperience" resultMap="PortalInterviewExperienceResult">
        <include refid="selectPortalInterviewExperienceVo"/>
        <where>  
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}, '%')
            </if>
            <if test="company != null and company != ''">
                AND company like concat('%', #{company}, '%')
            </if>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by view_count desc
    </select>
    
    <select id="selectPortalInterviewExperienceById" parameterType="Long" resultMap="PortalInterviewExperienceResult">
        <include refid="selectPortalInterviewExperienceVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertPortalInterviewExperience" parameterType="com.moyun.portal.domain.entity.PortalInterviewExperience" useGeneratedKeys="true" keyProperty="id">
        insert into portal_interview_experience
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="company != null and company != ''">company,</if>
            <if test="position != null and position != ''">position,</if>
            <if test="year != null">year,</if>
            <if test="month != null">month,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="tags != null and tags != ''">tags,</if>
            <if test="viewCount != null">view_count,</if>
            <if test="likeCount != null">like_count,</if>
            <if test="commentCount != null">comment_count,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null and remark != ''">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="company != null and company != ''">#{company},</if>
            <if test="position != null and position != ''">#{position},</if>
            <if test="year != null">#{year},</if>
            <if test="month != null">#{month},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="tags != null and tags != ''">#{tags},</if>
            <if test="viewCount != null">#{viewCount},</if>
            <if test="likeCount != null">#{likeCount},</if>
            <if test="commentCount != null">#{commentCount},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
         </trim>
    </insert>

    <update id="updatePortalInterviewExperience" parameterType="com.moyun.portal.domain.entity.PortalInterviewExperience">
        update portal_interview_experience
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="company != null and company != ''">company = #{company},</if>
            <if test="position != null and position != ''">position = #{position},</if>
            <if test="year != null">year = #{year},</if>
            <if test="month != null">month = #{month},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="tags != null and tags != ''">tags = #{tags},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="commentCount != null">comment_count = #{commentCount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePortalInterviewExperienceById" parameterType="Long">
        delete from portal_interview_experience where id = #{id}
    </delete>

    <delete id="deletePortalInterviewExperienceByIds" parameterType="Long">
        delete from portal_interview_experience where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
