<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalInterviewQuestionLikeMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalInterviewQuestionLike" id="PortalInterviewQuestionLikeResult">
        <id     property="id"          column="id"          />
        <result property="questionId"  column="question_id" />
        <result property="userId"      column="user_id"     />
        <result property="createTime"  column="create_time" />
    </resultMap>

    <select id="selectLike" resultMap="PortalInterviewQuestionLikeResult">
        select id, question_id, user_id, create_time
        from portal_interview_question_like
        where question_id = #{questionId} and user_id = #{userId}
        limit 1
    </select>

</mapper>
