<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalInterviewQuestionMapper">
    
    <resultMap type="com.moyun.portal.domain.entity.PortalInterviewQuestion" id="PortalInterviewQuestionResult">
        <id     property="id"          column="id"          />
        <result property="title"       column="title"       />
        <result property="description" column="description" />
        <result property="difficulty"  column="difficulty"  />
        <result property="categoryId"  column="category_id" />
        <result property="tags"        column="tags"        />
        <result property="companies"   column="companies"   />
        <result property="acceptanceRate" column="acceptance_rate" />
        <result property="submissionCount" column="submission_count" />
        <result property="likeCount"   column="like_count"  />
        <result property="hint"        column="hint"        />
        <result property="solution"    column="solution"    />
        <result property="sort"        column="sort"        />
        <result property="status"      column="status"      />
        <result property="createBy"    column="create_by"   />
        <result property="createTime"  column="create_time" />
        <result property="updateBy"    column="update_by"   />
        <result property="updateTime"  column="update_time" />
        <result property="remark"      column="remark"      />
    </resultMap>

    <sql id="selectPortalInterviewQuestionVo">
        select id, title, description, difficulty, category_id, tags, companies, acceptance_rate, submission_count, like_count, hint, solution, sort, status, create_by, create_time, update_by, update_time, remark 
        from portal_interview_question
    </sql>

    <select id="selectPortalInterviewQuestionList" parameterType="com.moyun.portal.domain.entity.PortalInterviewQuestion" resultMap="PortalInterviewQuestionResult">
        <include refid="selectPortalInterviewQuestionVo"/>
        <where>  
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}, '%')
            </if>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="difficulty != null and difficulty != ''">
                AND difficulty = #{difficulty}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by sort asc, like_count desc
    </select>
    
    <select id="selectPortalInterviewQuestionById" parameterType="Long" resultMap="PortalInterviewQuestionResult">
        <include refid="selectPortalInterviewQuestionVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertPortalInterviewQuestion" parameterType="com.moyun.portal.domain.entity.PortalInterviewQuestion" useGeneratedKeys="true" keyProperty="id">
        insert into portal_interview_question
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="description != null">description,</if>
            <if test="difficulty != null and difficulty != ''">difficulty,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="tags != null and tags != ''">tags,</if>
            <if test="companies != null and companies != ''">companies,</if>
            <if test="acceptanceRate != null">acceptance_rate,</if>
            <if test="submissionCount != null">submission_count,</if>
            <if test="likeCount != null">like_count,</if>
            <if test="hint != null">hint,</if>
            <if test="solution != null">solution,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null and remark != ''">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="description != null">#{description},</if>
            <if test="difficulty != null and difficulty != ''">#{difficulty},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="tags != null and tags != ''">#{tags},</if>
            <if test="companies != null and companies != ''">#{companies},</if>
            <if test="acceptanceRate != null">#{acceptanceRate},</if>
            <if test="submissionCount != null">#{submissionCount},</if>
            <if test="likeCount != null">#{likeCount},</if>
            <if test="hint != null">#{hint},</if>
            <if test="solution != null">#{solution},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
         </trim>
    </insert>

    <update id="updatePortalInterviewQuestion" parameterType="com.moyun.portal.domain.entity.PortalInterviewQuestion">
        update portal_interview_question
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="description != null">description = #{description},</if>
            <if test="difficulty != null and difficulty != ''">difficulty = #{difficulty},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="tags != null and tags != ''">tags = #{tags},</if>
            <if test="companies != null and companies != ''">companies = #{companies},</if>
            <if test="acceptanceRate != null">acceptance_rate = #{acceptanceRate},</if>
            <if test="submissionCount != null">submission_count = #{submissionCount},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="hint != null">hint = #{hint},</if>
            <if test="solution != null">solution = #{solution},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePortalInterviewQuestionById" parameterType="Long">
        delete from portal_interview_question where id = #{id}
    </delete>

    <delete id="deletePortalInterviewQuestionByIds" parameterType="Long">
        delete from portal_interview_question where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
