<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalInterviewResumeTemplateMapper">
    
    <resultMap type="com.moyun.portal.domain.entity.PortalInterviewResumeTemplate" id="PortalInterviewResumeTemplateResult">
        <id     property="id"           column="id"            />
        <result property="title"        column="title"         />
        <result property="description"  column="description"   />
        <result property="cover"        column="cover"         />
        <result property="downloadUrl"  column="download_url"  />
        <result property="category"     column="category"      />
        <result property="likeCount"    column="like_count"    />
        <result property="downloadCount" column="download_count" />
        <result property="sort"         column="sort"          />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectPortalInterviewResumeTemplateVo">
        select id, title, description, cover, download_url, category, like_count, download_count, sort, status, create_by, create_time, update_by, update_time, remark 
        from portal_interview_resume_template
    </sql>

    <select id="selectPortalInterviewResumeTemplateList" parameterType="com.moyun.portal.domain.entity.PortalInterviewResumeTemplate" resultMap="PortalInterviewResumeTemplateResult">
        <include refid="selectPortalInterviewResumeTemplateVo"/>
        <where>  
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}, '%')
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by sort asc, download_count desc
    </select>
    
    <select id="selectPortalInterviewResumeTemplateById" parameterType="Long" resultMap="PortalInterviewResumeTemplateResult">
        <include refid="selectPortalInterviewResumeTemplateVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertPortalInterviewResumeTemplate" parameterType="com.moyun.portal.domain.entity.PortalInterviewResumeTemplate" useGeneratedKeys="true" keyProperty="id">
        insert into portal_interview_resume_template
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="description != null">description,</if>
            <if test="cover != null and cover != ''">cover,</if>
            <if test="downloadUrl != null and downloadUrl != ''">download_url,</if>
            <if test="category != null and category != ''">category,</if>
            <if test="likeCount != null">like_count,</if>
            <if test="downloadCount != null">download_count,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null and remark != ''">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="description != null">#{description},</if>
            <if test="cover != null and cover != ''">#{cover},</if>
            <if test="downloadUrl != null and downloadUrl != ''">#{downloadUrl},</if>
            <if test="category != null and category != ''">#{category},</if>
            <if test="likeCount != null">#{likeCount},</if>
            <if test="downloadCount != null">#{downloadCount},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
         </trim>
    </insert>

    <update id="updatePortalInterviewResumeTemplate" parameterType="com.moyun.portal.domain.entity.PortalInterviewResumeTemplate">
        update portal_interview_resume_template
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="description != null">description = #{description},</if>
            <if test="cover != null and cover != ''">cover = #{cover},</if>
            <if test="downloadUrl != null and downloadUrl != ''">download_url = #{downloadUrl},</if>
            <if test="category != null and category != ''">category = #{category},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="downloadCount != null">download_count = #{downloadCount},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePortalInterviewResumeTemplateById" parameterType="Long">
        delete from portal_interview_resume_template where id = #{id}
    </delete>

    <delete id="deletePortalInterviewResumeTemplateByIds" parameterType="Long">
        delete from portal_interview_resume_template where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
