<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalInterviewSubmissionMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalInterviewSubmission" id="PortalInterviewSubmissionResult">
        <id     property="id"          column="id"          />
        <result property="questionId"  column="question_id" />
        <result property="userId"      column="user_id"     />
        <result property="code"        column="code"        />
        <result property="content"     column="content"     />
        <result property="language"    column="language"    />
        <result property="answerType"  column="answer_type" />
        <result property="status"      column="status"      />
        <result property="isSuccess"   column="is_success"  />
        <result property="runtime"     column="runtime"     />
        <result property="memoryUsage" column="memory_usage"/>
        <result property="note"        column="note"        />
        <result property="createTime"  column="create_time" />
    </resultMap>

    <sql id="selectPortalInterviewSubmissionVo">
        select id, question_id, user_id, code, content, language, answer_type, status, is_success, runtime, memory_usage, note, create_time
        from portal_interview_submission
    </sql>

    <!-- 查询某题目的所有提交记录（可按用户筛选） -->
    <select id="selectSubmissionsByQuestionAndUser" resultMap="PortalInterviewSubmissionResult">
        <include refid="selectPortalInterviewSubmissionVo"/>
        where question_id = #{questionId}
        <if test="userId != null">
            and user_id = #{userId}
        </if>
        order by create_time desc
    </select>

    <!-- 统计某题目的总提交次数 -->
    <select id="countSubmissionsByQuestion" resultType="long">
        select count(*) from portal_interview_submission where question_id = #{questionId}
    </select>

    <!-- 统计某题目的通过次数 -->
    <select id="countSuccessByQuestion" resultType="long">
        select count(*) from portal_interview_submission where question_id = #{questionId} and is_success = true
    </select>

</mapper>
