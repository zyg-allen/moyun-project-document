<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalLikeMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalLike" id="PortalLikeResult">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="articleId" column="article_id"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectPortalLikeVo">
        select id, user_id, article_id, create_time from portal_like
    </sql>

    <select id="selectPortalLikeList" parameterType="com.moyun.portal.domain.entity.PortalLike" resultMap="PortalLikeResult">
        <include refid="selectPortalLikeVo"/>
        <where>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="articleId != null">and article_id = #{articleId}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectPortalLikeById" parameterType="Long" resultMap="PortalLikeResult">
        <include refid="selectPortalLikeVo"/>
        where id = #{id}
    </select>

    <insert id="insertPortalLike" parameterType="com.moyun.portal.domain.entity.PortalLike" useGeneratedKeys="true" keyProperty="id">
        insert into portal_like
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="articleId != null">article_id,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="articleId != null">#{articleId},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updatePortalLike" parameterType="com.moyun.portal.domain.entity.PortalLike">
        update portal_like
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="articleId != null">article_id = #{articleId},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePortalLikeById" parameterType="Long">
        delete from portal_like where id = #{id}
    </delete>

    <delete id="deletePortalLikeByIds" parameterType="Long">
        delete from portal_like where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
