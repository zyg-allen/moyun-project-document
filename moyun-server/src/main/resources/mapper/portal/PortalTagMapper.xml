<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalTagMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalTag" id="PortalTagResult">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="slug" column="slug"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectPortalTagVo">
        select id, name, slug, sort, status, create_by, create_time, update_by, update_time, remark from portal_tag
    </sql>

    <select id="selectPortalTagList" parameterType="com.moyun.portal.domain.entity.PortalTag" resultMap="PortalTagResult">
        <include refid="selectPortalTagVo"/>
        <where>
            <if test="name != null and name != ''">and name like concat('%', #{name}, '%')</if>
            <if test="slug != null and slug != ''">and slug like concat('%', #{slug}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by sort asc, id asc
    </select>

    <select id="selectPortalTagById" parameterType="Long" resultMap="PortalTagResult">
        <include refid="selectPortalTagVo"/>
        where id = #{id}
    </select>

    <insert id="insertPortalTag" parameterType="com.moyun.portal.domain.entity.PortalTag" useGeneratedKeys="true" keyProperty="id">
        insert into portal_tag
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="slug != null">slug,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="slug != null">#{slug},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePortalTag" parameterType="com.moyun.portal.domain.entity.PortalTag">
        update portal_tag
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="slug != null">slug = #{slug},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePortalTagById" parameterType="Long">
        delete from portal_tag where id = #{id}
    </delete>

    <delete id="deletePortalTagByIds" parameterType="Long">
        delete from portal_tag where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
