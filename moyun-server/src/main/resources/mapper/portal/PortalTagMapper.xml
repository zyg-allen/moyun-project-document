<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moyun.portal.mapper.PortalTagMapper">

    <resultMap type="com.moyun.portal.domain.entity.PortalTag" id="PortalTagResult">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="slug" column="slug"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="module" column="module"/>
        <result property="referenceCount" column="reference_count"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectPortalTagVo">
        select id, name, slug, sort, status, module, reference_count, create_by, create_time, update_by, update_time, remark from portal_tag
    </sql>

    <!-- 通用查询条件片段 -->
    <sql id="queryWhere">
        <where>
            <if test="params.name != null and params.name != ''">
                AND name like concat('%', #{params.name}, '%')
            </if>
            <if test="params.status != null and params.status != ''">
                AND status = #{params.status}
            </if>
            <if test="params.module != null and params.module != ''">
                AND module = #{params.module}
            </if>
        </where>
    </sql>

    <!-- 通用排序片段（默认排序） -->
    <sql id="defaultOrderBy">
        order by sort asc, id asc
    </sql>

    <!-- 动态排序片段 -->
    <sql id="dynamicOrderBy">
        <if test="params.orderByColumn != null and params.orderByColumn != ''">
            order by ${params.orderByColumn}
            <if test="params.isAsc != null and params.isAsc != ''">
                ${params.isAsc}
            </if>
        </if>
        <if test="params.orderByColumn == null or params.orderByColumn == ''">
            <include refid="defaultOrderBy"/>
        </if>
    </sql>

    <!-- 分页查询 -->
    <select id="selectPortalTagPage" resultMap="PortalTagResult">
        <include refid="selectPortalTagVo"/>
        <include refid="queryWhere"/>
        <include refid="dynamicOrderBy"/>
    </select>

    <!-- 不分页查询（用于导出等场景） -->
    <select id="selectPortalTagList" resultMap="PortalTagResult">
        <include refid="selectPortalTagVo"/>
        <include refid="queryWhere"/>
        <include refid="defaultOrderBy"/>
    </select>

    <select id="selectPortalTagById" parameterType="Long" resultMap="PortalTagResult">
        <include refid="selectPortalTagVo"/>
        where id = #{id}
    </select>

    <insert id="insertPortalTag" parameterType="com.moyun.portal.domain.entity.PortalTag" useGeneratedKeys="true" keyProperty="id">
        insert into portal_tag
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="slug != null">slug,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null">status,</if>
            <if test="module != null">module,</if>
            <if test="referenceCount != null">reference_count,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="slug != null">#{slug},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null">#{status},</if>
            <if test="module != null">#{module},</if>
            <if test="referenceCount != null">#{referenceCount},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePortalTag" parameterType="com.moyun.portal.domain.entity.PortalTag">
        update portal_tag
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="slug != null">slug = #{slug},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="module != null">module = #{module},</if>
            <if test="referenceCount != null">reference_count = #{referenceCount},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePortalTagById" parameterType="Long">
        delete from portal_tag where id = #{id}
    </delete>

    <delete id="deletePortalTagByIds" parameterType="Long">
        delete from portal_tag where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectByNameAndModule" resultMap="PortalTagResult">
        <include refid="selectPortalTagVo"/>
        where name = #{name}
        <if test="module != null and module != ''">
            AND module = #{module}
        </if>
        <if test="module == null or module == ''">
            AND (module is null or module = '')
        </if>
        limit 1
    </select>

    <select id="selectTagsByEntity" resultMap="PortalTagResult">
        <include refid="selectPortalTagVo"/>
        where id in (
            select tag_id from portal_entity_tag
            where entity_type = #{entityType} and entity_id = #{entityId}
        )
        order by sort asc, id asc
    </select>

    <select id="selectHotTags" resultMap="PortalTagResult">
        <include refid="selectPortalTagVo"/>
        <where>
            <if test="module != null and module != ''">
                AND module = #{module}
            </if>
            AND (reference_count is null or reference_count > 0)
        </where>
        order by reference_count desc, sort asc, id asc
        limit #{limit}
    </select>

    <update id="updateReferenceCountBatch">
        UPDATE portal_tag SET reference_count = COALESCE(reference_count, 0) + #{delta} WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
    </update>
    <update id="updateReferenceCount">
        UPDATE portal_tag SET reference_count = COALESCE(reference_count, 0) + #{delta} WHERE id = #{id}
    </update>
</mapper>
